# .env.example — copy to .env and fill in values before running docker compose

# --- PostgreSQL ---
POSTGRES_USER=simplyfiles
POSTGRES_PASSWORD=simplyfiles
POSTGRES_DB=simplyfiles

# --- Backend ---
PORT=3001
MAX_UPLOAD_SIZE=524288000
SEARCH_LANG=english
SEARCH_CHUNK_SIZE=1500
OCR_ENABLED=true
CORS_ORIGIN=http://localhost:23739

# --- Frontend ---
MAX_FOLDER_DEPTH=5

# --- Version (optional) ---
# APP_VERSION=latest
